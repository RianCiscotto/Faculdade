Window functions no SQL realizam cálculos em um conjunto de linhas relacionadas à linha atual (uma "janela"), 
sem agrupar o resultado final em uma única linha. Elas são ideais para totais acumulados, médias móveis e 
rankings, mantendo todas as linhas originais da tabela enquanto adicionam o valor calculado. 
______________________________________________________________________________________________________________















CREATE DATABASE aula_window_exercicio;
USE aula_window_exercicio;

CREATE TABLE vendedores (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    equipe VARCHAR(50) NOT NULL
);

CREATE TABLE vendas (
    id INT PRIMARY KEY AUTO_INCREMENT,
    vendedor_id INT NOT NULL,
    data_venda DATE NOT NULL,
    produto VARCHAR(100) NOT NULL,
    categoria VARCHAR(50) NOT NULL,
    valor DECIMAL(10,2) NOT NULL,
    quantidade INT NOT NULL,
    FOREIGN KEY (vendedor_id) REFERENCES vendedores(id)
);


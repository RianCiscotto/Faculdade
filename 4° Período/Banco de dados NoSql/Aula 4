SELECT 
    vendedores.nome AS vendedor, 
    vendas.data_venda, 
    vendas.valor,
    SUM(vendas.valor) OVER (
        PARTITION BY vendedores.id 
        ORDER BY vendas.data_venda
    ) AS total_acumulado
FROM vendedores
JOIN vendas ON vendedores.id = vendas.vendedor_id
ORDER BY 
    vendedores.nome, 
    vendas.data_venda;


